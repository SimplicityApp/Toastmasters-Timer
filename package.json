{
  "name": "toastmaster-timer",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo: Zoom app (apps/zoom-app) and marketing + web app (apps/web)",
  "type": "module",
  "dependencies": {
    "@vercel/functions": "^3.0.0"
  },
  "scripts": {
    "install:zoom": "npm install --prefix apps/zoom-app",
    "install:web": "npm install --prefix apps/web",
    "dev": "npm run dev --prefix apps/zoom-app",
    "build": "npm run build:web && npm run build --prefix apps/zoom-app && npm run combine:dist",
    "build:web": "npm run build --prefix apps/web",
    "build:zoom-standalone": "VITE_BASE_PATH=/ npm run build --prefix apps/zoom-app",
    "combine:dist": "rm -rf dist && mkdir -p dist/zoom && cp -r apps/web/dist/. dist/ && cp -r apps/zoom-app/dist/. dist/zoom/",
    "preview": "npm run preview --prefix apps/zoom-app",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:zoom": "npm run dev --prefix apps/zoom-app",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18"
  }
}
